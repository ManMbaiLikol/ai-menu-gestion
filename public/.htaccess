# SPA fallback — toutes les routes inconnues renvoient index.html (React Router côté client)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# index.html ne doit JAMAIS être mis en cache : c'est lui qui pointe vers le
# bundle JS/CSS hashé. Les assets hashés (/assets/*) restent, eux, cacheables.
<IfModule mod_headers.c>
  <FilesMatch "index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>
</IfModule>
